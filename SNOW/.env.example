# =============================================================================
# Snowflake Trust Center to Google SecOps integration
# Copy this file to .env and replace the placeholder values.
# =============================================================================

# ---------------------------------------------------------------------------
# Snowflake account 1 (required)
# ---------------------------------------------------------------------------
# Account locator example: xy12345.us-east-1 or xy12345.east-us-2.azure
SNOWFLAKE_ACCOUNT_1=example-prod-account.us-east-1
SNOWFLAKE_USER_1=svc_trust_center
# Path to a PKCS#8 private key file used for SNOWFLAKE_JWT authentication
SNOWFLAKE_PRIVATE_KEY_PATH_1=~/.snowflake/keys/prod_rsa_key.p8
# Optional passphrase for the private key file
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE_1=
# Must have TRUST_CENTER_VIEWER database role (or ACCOUNTADMIN)
SNOWFLAKE_ROLE_1=TRUST_CENTER_VIEWER
SNOWFLAKE_WAREHOUSE_1=COMPUTE_WH
# Human-readable label shown in reports and Chronicle ingestion_labels
SNOWFLAKE_LABEL_1=prod

# ---------------------------------------------------------------------------
# Snowflake account 2 (optional)
# ---------------------------------------------------------------------------
# Leave the account, user, and private key path blank to skip this account.
SNOWFLAKE_ACCOUNT_2=
SNOWFLAKE_USER_2=
SNOWFLAKE_PRIVATE_KEY_PATH_2=
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE_2=
SNOWFLAKE_ROLE_2=TRUST_CENTER_VIEWER
SNOWFLAKE_WAREHOUSE_2=COMPUTE_WH
SNOWFLAKE_LABEL_2=dev
# Example values if you want to enable account 2:
# SNOWFLAKE_ACCOUNT_2=example-dev-account.us-west-2
# SNOWFLAKE_USER_2=svc_trust_center_dev
# SNOWFLAKE_PRIVATE_KEY_PATH_2=~/.snowflake/keys/dev_rsa_key.p8
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE_2=replace_me_if_encrypted

# ---------------------------------------------------------------------------
# Snowflake account 3 (optional)
# ---------------------------------------------------------------------------
# Leave the account, user, and private key path blank to skip this account.
SNOWFLAKE_ACCOUNT_3=
SNOWFLAKE_USER_3=
SNOWFLAKE_PRIVATE_KEY_PATH_3=
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE_3=
SNOWFLAKE_ROLE_3=TRUST_CENTER_VIEWER
SNOWFLAKE_WAREHOUSE_3=COMPUTE_WH
SNOWFLAKE_LABEL_3=staging
# Example values if you want to enable account 3:
# SNOWFLAKE_ACCOUNT_3=example-staging-account.eu-west-1
# SNOWFLAKE_USER_3=svc_trust_center_staging
# SNOWFLAKE_PRIVATE_KEY_PATH_3=~/.snowflake/keys/staging_rsa_key.p8
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE_3=replace_me_if_encrypted

# ---------------------------------------------------------------------------
# Google SecOps (Chronicle)
# ---------------------------------------------------------------------------
# Full webhook feed endpoint. It may already include ?key=<API_KEY>&secret=<SECRET>.
SECOPS_WEBHOOK_URL=https://us-chronicle.rep.googleapis.com/v1alpha/projects/<PROJECT_ID>/locations/us/instances/<INSTANCE_ID>:importPushLogs?key=<API_KEY>&secret=<SECRET>
# Optional fallback API key. Used only if SECOPS_WEBHOOK_URL does not include key=...
SECOPS_API_KEY=
# Optional fallback webhook secret. Used only if SECOPS_WEBHOOK_URL does not include secret=...
SECOPS_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Behavior
# ---------------------------------------------------------------------------
# Number of past days to fetch findings for
LOOKBACK_DAYS=7
# Maximum events per POST request to SecOps. The notebook also enforces a 4 MB request cap.
BATCH_SIZE=100
# Set to true to run the full pipeline without sending events to SecOps
DRY_RUN=false
# Local path for the exported Excel report
EXPORT_PATH=./trust_center_report.xlsx
