# =============================================================================
# Snowflake security checks to Google SecOps integration
# Copy this file to .env and replace the placeholder values.
# =============================================================================

# ---------------------------------------------------------------------------
# Snowflake account 1 (required)
# ---------------------------------------------------------------------------
# Account locator example: xy12345.us-east-1 or xy12345.east-us-2.azure
SNOWFLAKE_ACCOUNT_1=example-prod-account.us-east-1
SNOWFLAKE_USER_1=svc_security_checks
# Path to a PKCS#8 private key file used for SNOWFLAKE_JWT authentication
SNOWFLAKE_PRIVATE_KEY_PATH_1=~/.snowflake/keys/prod_rsa_key.p8
# Optional passphrase for the private key file
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE_1=
# Optional role and warehouse. Use the least privileged values that can run your queries.
SNOWFLAKE_ROLE_1=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE_1=COMPUTE_WH
# Human-readable label shown in the notebook UI
SNOWFLAKE_LABEL_1=prod

# ---------------------------------------------------------------------------
# Snowflake account 3 (optional)
# ---------------------------------------------------------------------------
# Account numbering may be sparse. Leave the account blank to skip an index.
SNOWFLAKE_ACCOUNT_3=example-staging-account.eu-west-1
SNOWFLAKE_USER_3=svc_security_checks_staging
SNOWFLAKE_PRIVATE_KEY_PATH_3=~/.snowflake/keys/staging_rsa_key.p8
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE_3=
SNOWFLAKE_ROLE_3=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE_3=COMPUTE_WH
SNOWFLAKE_LABEL_3=staging

# ---------------------------------------------------------------------------
# Security checks
# ---------------------------------------------------------------------------
# Use SQL files for long queries. Relative paths are resolved from the notebook directory.
SECURITY_CHECK_NAME_1=login_history_activity
SECURITY_CHECK_SQL_FILE_1=sql_checks/login_history_activity.sql

SECURITY_CHECK_NAME_2=query_history_activity
SECURITY_CHECK_SQL_FILE_2=sql_checks/query_history_activity.sql

SECURITY_CHECK_NAME_3=access_history_activity
SECURITY_CHECK_SQL_FILE_3=sql_checks/access_history_activity.sql

SECURITY_CHECK_NAME_4=grants_to_users_changes
SECURITY_CHECK_SQL_FILE_4=sql_checks/grants_to_users_changes.sql

SECURITY_CHECK_NAME_5=grants_to_roles_changes
SECURITY_CHECK_SQL_FILE_5=sql_checks/grants_to_roles_changes.sql

SECURITY_CHECK_NAME_6=trust_center_findings
SECURITY_CHECK_SQL_FILE_6=sql_checks/trust_center_findings.sql

# Inline SQL remains available as a fallback when no SQL file is configured.
# SECURITY_CHECK_NAME_7=custom_control_check
# SECURITY_CHECK_SQL_7="SELECT CURRENT_ACCOUNT() AS account_name"

# ---------------------------------------------------------------------------
# Google SecOps
# ---------------------------------------------------------------------------
# Full webhook feed endpoint. Keep auth values separate in SECOPS_API_KEY and
# SECOPS_WEBHOOK_SECRET unless you intentionally use query-string auth.
SECOPS_WEBHOOK_URL=https://us-chronicle.rep.googleapis.com/v1alpha/projects/<PROJECT_ID>/locations/us/instances/<INSTANCE_ID>:importPushLogs
# Google SecOps API key loaded from .env when the webhook URL does not include key=...
SECOPS_API_KEY=<API_KEY>
# Google SecOps webhook secret loaded from .env when the webhook URL does not include secret=...
SECOPS_WEBHOOK_SECRET=<SECRET>

# ---------------------------------------------------------------------------
# Behavior
# ---------------------------------------------------------------------------
# Comma-separated labels and check keys for the headless daily runner.
# Use `all` by itself to run every configured account or check.
SELECTED_ACCOUNTS=prod
SELECTED_CHECKS=login_history_activity,query_history_activity

# Maximum events per POST request to SecOps. The notebook also enforces a 4 MB request cap.
BATCH_SIZE=100
# Set the notebook default run mode. The control panel can still switch between
# DRY_RUN and LIVE before executing or sending selected rows.
DRY_RUN=false
