# =============================================================================
# Snowflake security checks to Google SecOps integration
# Copy this file to .env and replace the placeholder values.
# =============================================================================

# ---------------------------------------------------------------------------
# Snowflake account 1 (required)
# ---------------------------------------------------------------------------
# Account locator example: xy12345.us-east-1 or xy12345.east-us-2.azure
SNOWFLAKE_ACCOUNT_1=example-prod-account.us-east-1
SNOWFLAKE_USER_1=svc_security_checks
# Path to a PKCS#8 private key file used for SNOWFLAKE_JWT authentication
SNOWFLAKE_PRIVATE_KEY_PATH_1=~/.snowflake/keys/prod_rsa_key.p8
# Optional passphrase for the private key file
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE_1=
# Optional role and warehouse. Use the least privileged values that can run your queries.
SNOWFLAKE_ROLE_1=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE_1=COMPUTE_WH
# Human-readable label shown in the notebook UI
SNOWFLAKE_LABEL_1=prod

# ---------------------------------------------------------------------------
# Snowflake account 3 (optional)
# ---------------------------------------------------------------------------
# Account numbering may be sparse. Leave the account blank to skip an index.
SNOWFLAKE_ACCOUNT_3=example-staging-account.eu-west-1
SNOWFLAKE_USER_3=svc_security_checks_staging
SNOWFLAKE_PRIVATE_KEY_PATH_3=~/.snowflake/keys/staging_rsa_key.p8
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE_3=
SNOWFLAKE_ROLE_3=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE_3=COMPUTE_WH
SNOWFLAKE_LABEL_3=staging

# ---------------------------------------------------------------------------
# Security checks
# ---------------------------------------------------------------------------
# Use quoted strings when you need multiline SQL. The notebook converts \n
# into real line breaks before execution.
SECURITY_CHECK_NAME_1=users_without_mfa
SECURITY_CHECK_SQL_1="SELECT USER_NAME, LOGIN_NAME, CREATED_ON\nFROM SNOWFLAKE.ACCOUNT_USAGE.USERS\nWHERE HAS_MFA = FALSE\nORDER BY CREATED_ON DESC\nLIMIT 100"

SECURITY_CHECK_NAME_2=network_policies
SECURITY_CHECK_SQL_2="SHOW NETWORK POLICIES"

# Optional additional checks
# SECURITY_CHECK_NAME_5=sessions_without_policy
# SECURITY_CHECK_SQL_5="SELECT *\nFROM MY_DB.MY_SCHEMA.MY_VIEW\nLIMIT 100"

# ---------------------------------------------------------------------------
# Google SecOps
# ---------------------------------------------------------------------------
# Full webhook feed endpoint. It may already include ?key=<API_KEY>&secret=<SECRET>.
SECOPS_WEBHOOK_URL=https://us-chronicle.rep.googleapis.com/v1alpha/projects/<PROJECT_ID>/locations/us/instances/<INSTANCE_ID>:importPushLogs?key=<API_KEY>&secret=<SECRET>
# Optional fallback API key. Used only if SECOPS_WEBHOOK_URL does not include key=...
SECOPS_API_KEY=
# Optional fallback webhook secret. Used only if SECOPS_WEBHOOK_URL does not include secret=...
SECOPS_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Behavior
# ---------------------------------------------------------------------------
# Maximum events per POST request to SecOps. The notebook also enforces a 4 MB request cap.
BATCH_SIZE=100
# Set to true to preview batches without sending any network traffic
DRY_RUN=false
